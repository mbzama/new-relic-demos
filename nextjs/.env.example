# New Relic APM (server-side)
NEW_RELIC_LICENSE_KEY=your_license_key_here
NEW_RELIC_APP_NAME=NextJS-NewRelic-Demo
NEW_RELIC_LOG_LEVEL=info

# New Relic Browser Monitoring
# Set to 'false' to disable browser agent injection
NEW_RELIC_BROWSER_MONITORING_ENABLE=true

# NestJS Backend API
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Browser agent config (from NR browser app settings)
NEXT_PUBLIC_NR_ACCOUNT_ID=your_account_id
NEXT_PUBLIC_NR_AGENT_ID=your_agent_id
NEXT_PUBLIC_NR_LICENSE_KEY=your_browser_license_key
NEXT_PUBLIC_NR_APPLICATION_ID=your_application_id
