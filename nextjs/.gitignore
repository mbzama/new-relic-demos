.env
.env.local
.env.*.local

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
newrelic_agent.log

# testing
/coverage

# typescript
*.tsbuildinfo
next-env.d.ts

# vercel
.vercel

# misc
.DS_Store
Thumbs.db
*.pem
