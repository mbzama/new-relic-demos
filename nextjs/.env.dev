# ── Server-side APM (Next.js instrumentation via @newrelic/next) ──────────────
NEW_RELIC_LICENSE_KEY=XXXXXXX
NEW_RELIC_APP_NAME=nextjs-demo-local
NEW_RELIC_LOG_LEVEL=info
NEW_RELIC_BROWSER_MONITORING_ENABLE=true

# ── App ───────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── NestJS backend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ── Browser agent (copy values from NR UI → Browser → your app → Settings) ───
NEXT_PUBLIC_NR_ACCOUNT_ID=XXXXXXX
NEXT_PUBLIC_NR_AGENT_ID=XXXXXXX
NEXT_PUBLIC_NR_LICENSE_KEY=NRBR-XXXXXXX
NEXT_PUBLIC_NR_APPLICATION_ID=XXXXXXX
